# ─────────────────────────────────────────────────────────────────────────
# Canada Immigration & PR Navigator — environment configuration template
# Copy to .env and fill in secrets. .env is gitignored.
# ─────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────
ENV=development                 # development | staging | production
LOG_LEVEL=INFO
LOG_JSON=false                  # true in production for structured logs
WEB_HOST=0.0.0.0
WEB_PORT=5050

# ── LLM (OpenAI-compatible endpoint; provider-agnostic) ────────────────────
# Production: deepseek-v4-flash via Volcengine ark. Swap freely — only these
# env vars change to use OpenAI / a self-hosted vLLM / the old course endpoint.
LLM_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
LLM_API_KEY=<your_token>
LLM_MODEL=deepseek-v4-flash-260425
LLM_TIMEOUT_SECONDS=45
LLM_CONTEXT_WINDOW_TOKENS=65536
LLM_MAX_OUTPUT_TOKENS=2048
LLM_TEMPERATURE=0.1

# ── Embeddings (multilingual EN/ZH) ────────────────────────────────────────
EMBEDDING_PROVIDER=bge          # bge (local, multilingual) | openai
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu            # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=32

# ── Reranker (cross-encoder, multilingual) ─────────────────────────────────
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu

# ── Database (Postgres + pgvector) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag
DB_USER=rag
DB_PASSWORD=rag
# DB_URL_OVERRIDE=postgresql://user:pass@host:5432/db   # optional single DSN

# ── Retrieval ──────────────────────────────────────────────────────────────
RETRIEVAL_BACKEND=pgvector      # pgvector | chroma (legacy)
RETRIEVAL_TOP_K_INITIAL=20
RETRIEVAL_TOP_K_FINAL=5
RETRIEVAL_RRF_K=60
RETRIEVAL_USE_RERANKER=true
